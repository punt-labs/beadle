      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(ftp:*)",
      "Bash(tftp:*)",
      "Bash(nc:*)",
      "Bash(netcat:*)",
      "Bash(ncat:*)",
      "Bash(telnet:*)",
      "Bash(socat:*)",
      "Edit(.env)",
      "Write(.env)",
      "Edit(.envrc)",
      "Write(.envrc)",
      "Bash(direnv allow:*)"
    ]
  }
